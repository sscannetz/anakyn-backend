# ── Database (Supabase / Railway / self-host) ──
DATABASE_URL=postgresql://user:password@host:5432/anakyn_gems
# ตัวอย่าง Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── JWT Auth ──
JWT_SECRET=เปลี่ยนเป็นข้อความสุ่มยาวๆ_อย่าใช้ค่านี้จริง
JWT_EXPIRES_IN=7d

# ── Server ──
PORT=4000
NODE_ENV=development

# ── CORS ──
FRONTEND_URL=http://localhost:5173
